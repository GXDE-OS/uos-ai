Source: uos-ai
Section: non-free/copilot
Priority: optional
Maintainer: deepin <packages@deepin.com>
Build-Depends:
 debhelper (>= 9),
 cmake,
 pkg-config,
 libatspi2.0-dev,
 libdocparser-dev,
 libjwt-dev,
 libssl-dev,
 fcitx-libs-dev,
 qtbase5-dev,
 qttools5-dev-tools,
 qtwebengine5-dev,
 qtmultimedia5-dev,
 libqt5websockets5-dev,
 libdtkwidget-dev,
 dde-dock-dev,
 libdtkocr-dev,
 libqt5waylandclient5-dev,
 libkf5wayland-dev

Standards-Version: 4.5.0
Package: uos-ai
Architecture: any
Depends:
 ${shlibs:Depends},${misc:Depends}
Description: As a useful and efficient assistant, an AI-powered assistant simplifies our office efficiency and provides valuable support in a wide range of domains.

Package: uos-ai-model-plugin
Architecture: any
Depends:
 ${shlibs:Depends},
 ${misc:Depends},
 uos-ai
Description: Model plugins for UOS AI assistant
 This package contains various model plugins for UOS AI assistant,
 including different AI model implementations and configurations.
